                      ]
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "QhLY7",
                  "name": "Scroll Body",
                  "clip": true,
                  "width": "fill_container",
                  "height": "fill_container",
                  "layout": "vertical",
                  "gap": 14,
                  "padding": [
                    26,
                    44
                  ],
                  "children": [
                    {
                      "type": "text",
                      "id": "O50dsY",
                      "name": "Eyebrow",
                      "fill": "$accent",
                      "content": "NỐI TIẾP ÔNG, CHA BIÊN GIA PHẢ",
                      "fontFamily": "$font-body",
                      "fontSize": 12,
                      "fontWeight": "600",
                      "letterSpacing": 1.5
                    },
                    {
                      "type": "text",
                      "id": "ZIerN",
                      "name": "P",
                      "fill": "$fg-primary",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Sau mấy mươi năm, gián đoạn về thời gian, trăn trở về cách làm… Nhưng những năm gần đây, ơn nhờ anh linh của Tổ tiên đã linh ứng, chỉ đường hướng lối cho hậu duệ của gia tộc, tiếp tục được công việc biên soạn nối tiếp gia phả của Dòng họ.",
                      "lineHeight": 1.85,
                      "fontFamily": "Newsreader",
                      "fontSize": 15,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "r5AghB",
                      "name": "P",
                      "fill": "$fg-primary",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Kể từ ngày cụ Ngô Phúc Khang, Thủy tổ của họ Ngô Phú Cốc, khoảng đời vua Lê Hy Tông (1681-1705); đến vùng đất này, khai phá đất hoang cuốc đất, lập nền, dựng nhà, gieo lúa trồng khoai, sinh con, đẻ cháu…đến nay đã là 14 đời, hậu duệ đã có tới mấy trăm hộ gia đình, đông đúc con cháu đang sinh cơ lập nghiệp ở quê hương và nhiều vùng của đất nước.",
                      "lineHeight": 1.85,
                      "fontFamily": "Newsreader",
                      "fontSize": 15,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "K8dX6E",
                      "name": "P",
                      "fill": "$fg-primary",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Theo thời gian, một số dòng họ cũng tụ cư về đây, cùng với họ Ngô, chung sức đồng lòng xây dựng nên làng Phú Liễn xưa, làng Phú Cốc bây giờ có truyền thống văn hóa và trù phú như ngày nay.",
                      "lineHeight": 1.85,
                      "fontFamily": "Newsreader",
                      "fontSize": 15,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "biBdY",
                      "name": "P",
                      "fill": "$fg-primary",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Việc biên soạn cuốn gia phả của dòng họ Ngô thôn Phú Cốc vừa là đáp ứng nguyện vọng và nhu cầu của mọi thành viên xa gần của gia tộc, bởi nhẽ “Quốc phải có sử biên”, “Họ phải có phả hệ” và cũng là thực hiện lời dặn lại của cụ Tổng sư Trần Ngỗi, năm 1941, khi dịch bản ghi chép của các cụ đời trước, từ chữ nho sang chữ quốc ngữ…",
                      "lineHeight": 1.85,
                      "fontFamily": "Newsreader",
                      "fontSize": 15,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "jwzeN",
                      "name": "P",
                      "fill": "$fg-primary",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Có điều là, việc thu thập thông tin của các thành viên trong họ, sẽ gặp một số khó khăn về địa lý, cũng như hoàn cảnh sinh kế của một số thành viên ở xa…Từ đó đòi hỏi Ban biên soạn nối tiếp gia phả phải kiên trì và có quyết tâm cao… mới hoàn thành được nội dung công việc đã đề ra.",
                      "lineHeight": 1.85,
                      "fontFamily": "Newsreader",
                      "fontSize": 15,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "w52fr",
                      "name": "P",
                      "fill": "$fg-primary",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Đọc và càng thấm thía ý nghĩa bốn chữ ghi trên bức Đại tự Nhà thờ Họ: “Hữu khai tất tiên”, có nghĩa là, con cháu được như ngày hôm nay là nhờ có sự mở mang, dạy giỗ, phúc ấm… của Tổ tiên. Thời gian nối tiếp thời gian, như dòng tộc ta đây, đã hơn 300 năm trải qua bao cuộc biến động của xã hội “Bãi bể, nương dâu”, nhưng dòng họ vẫn không ngừng phát triển.",
                      "lineHeight": 1.85,
                      "fontFamily": "Newsreader",
                      "fontSize": 15,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "xB7We",
                      "name": "P",
                      "fill": "$fg-primary",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Ở thời đại nào đều có người họ Ngô gánh vác công việc xã hội, nhiều người được cấp trên tin dùng, nhân dân tín nhiệm. Con cháu có người đã có học hàm tiến sỹ, thạc sỹ, nhiều cháu có trình độ kỹ sư, cử nhân… lại có người trong lực lượng vũ trang được phong quân hàm Trung tá, Thượng tá, Đại tá.",
                      "lineHeight": 1.85,
                      "fontFamily": "Newsreader",
                      "fontSize": 15,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "tzMwm",
                      "name": "P",
                      "fill": "$fg-primary",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Trong cuộc kháng chiến giành độc lập dân tộc, thống nhất đất nước và bảo vệ Tổ quốc, Dòng họ có 13 người thân là liệt sỹ, anh dũng hy sinh cho sự nghiệp cách mạng vẻ vang của đất nước.",
                      "lineHeight": 1.85,
                      "fontFamily": "Newsreader",
                      "fontSize": 15,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "d96JO",
                      "name": "P",
                      "fill": "$fg-primary",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Gia phả của Dòng họ hôm nay, được soạn thảo viết lại là kế thừa tinh hoa, gìn giữ nguyên trạng những tư liệu quý của các bậc tiền nhân truyền lại; đã được Hội đồng gia tộc, Ban biên tập tiếp thu ghi nhận.",
                      "lineHeight": 1.85,
                      "fontFamily": "Newsreader",
                      "fontSize": 15,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "M88CR",
                      "name": "P",
                      "fill": "$fg-primary",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Trong quá trình biên soạn Gia phả của Dòng tộc, sẽ không tránh khỏi sự nhầm lẫn và thiếu sót, kính mong các cụ, các ông, các bà và thành viên trong Dòng tộc tham gia góp ý, cung cấp thêm những tư liệu chính xác để bổ sung.",
                      "lineHeight": 1.85,
                      "fontFamily": "Newsreader",
                      "fontSize": 15,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "oAjKB",
                      "name": "P",
                      "fill": "$fg-primary",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Kính mong tôn linh Tổ tiên và các bậc tiền nhân, hương linh của những người đã quá cố được siêu âm, tịnh độ, phù hộ cho con cháu trong Dòng tộc được bình an và Họ tộc ta ngày hưng thịnh.",
                      "lineHeight": 1.85,
                      "fontFamily": "Newsreader",
                      "fontSize": 15,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "riNVP",
                      "name": "Sign",
                      "fill": "$fg-secondary",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Ngày 15 tháng 8 năm 2020 — KÍNH TỰA",
                      "textAlign": "right",
                      "fontFamily": "Newsreader",
                      "fontSize": 15,
                      "fontWeight": "normal",
                      "fontStyle": "italic"
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "CtdNz",
                  "name": "Footer",
                  "width": "fill_container",
                  "fill": "$surface-primary",
                  "stroke": "$border-subtle",
