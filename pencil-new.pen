                    },
                    {
                      "type": "text",
                      "id": "J8lJm",
                      "name": "Lead",
                      "fill": "$fg-secondary",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Từ một cụ Thủy tổ đến vùng đất Phú Cốc khai hoang, dòng họ Ngô đã trải qua hơn ba thế kỷ dựng xây và tiếp nối.",
                      "lineHeight": 1.6,
                      "fontFamily": "Newsreader",
                      "fontSize": 19,
                      "fontWeight": "normal",
                      "fontStyle": "italic"
                    },
                    {
                      "type": "text",
                      "id": "YGQew",
                      "name": "P1",
                      "fill": "$fg-primary",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Kể từ ngày cụ Ngô Phúc Khang, Thủy tổ của họ Ngô Phú Cốc, đến vùng đất này khoảng đời vua Lê Hy Tông (1681–1705); khai phá đất hoang, cuốc đất, lập nền, dựng nhà, gieo lúa trồng khoai, sinh con đẻ cháu… đến nay đã là 14 đời, hậu duệ đã có tới mấy trăm hộ gia đình.",
                      "lineHeight": 1.85,
                      "fontFamily": "Newsreader",
                      "fontSize": 17,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "sekRi",
                      "name": "H2",
                      "fill": "$fg-primary",
                      "content": "Mở đất, lập làng",
                      "fontFamily": "$font-heading",
                      "fontSize": 24,
                      "fontWeight": "600"
                    },
                    {
                      "type": "text",
                      "id": "d8RNR",
                      "name": "P2",
                      "fill": "$fg-primary",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Theo thời gian, một số dòng họ cũng tụ cư về đây, cùng với họ Ngô chung sức đồng lòng xây dựng nên làng Phú Liễn xưa — làng Phú Cốc ngày nay, có truyền thống văn hóa và trù phú như hiện tại.",
                      "lineHeight": 1.85,
                      "fontFamily": "Newsreader",
                      "fontSize": 17,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "frame",
                      "id": "xnmay",
                      "name": "Quote",
                      "width": "fill_container",
                      "fill": "$surface-card",
                      "cornerRadius": 12,
                      "stroke": "$accent",
                      "strokeWidth": {
                        "left": 4
                      },
                      "layout": "vertical",
                      "padding": [
                        22,
                        28
                      ],
                      "children": [
                        {
                          "type": "text",
                          "id": "wJ7lz",
                          "name": "T",
                          "fill": "$fg-primary",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "“Hữu khai tất tiên” — con cháu được như ngày hôm nay là nhờ sự mở mang, dạy giỗ, phúc ấm của Tổ tiên.",
                          "lineHeight": 1.5,
                          "fontFamily": "Newsreader",
                          "fontSize": 21,
