                      "width": "fill_container",
                      "content": "Nhà thờ Họ Ngô tại Phú Cốc — nơi con cháu hội tụ mỗi dịp giỗ Tổ.",
                      "textAlign": "center",
                      "fontFamily": "$font-body",
                      "fontSize": 13,
