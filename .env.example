# ===== Frontend (Vite) =====
# Sao chép thành .env rồi điền giá trị thật:  cp .env.example .env
#
# URL GỐC của project (KHÔNG kèm /rest/v1). Vd: https://kkftuhknxhacldiyrdxt.supabase.co
VITE_SUPABASE_URL=https://xxxx.supabase.co

# ANON key (public) — an toàn để nhúng vào frontend. RLS bảo vệ ghi dữ liệu.
VITE_SUPABASE_ANON_KEY=eyJ...

# Email thật của tài khoản admin trên Supabase Auth (người dùng KHÔNG cần biết)
VITE_ADMIN_EMAIL=admin@giapha.local

# Username hiển thị để người dùng nhập ở ô đăng nhập (ánh xạ tới email trên)
VITE_ADMIN_USERNAME=admin
