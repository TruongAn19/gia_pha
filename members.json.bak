  {
    "id_temp": "ngo-the-trinh",
    "name": "Ngô Thế Trịnh",
    "han_name": null,
    "generation": 12,
    "death_anniversary": null,
    "grave": null,
    "details": "Là con thứ tư cụ Ngô Thế Thập (Sinh mẫu là người họ Nguyễn). Sinh năm\n1957. Bộ đội tham gia chiến đấu ở Căm Pu Chia và Phía Bắc, chuyển ngành,\nlàm việc ở Xí nghiệp Bê tông Thăng Long, Hà Nội. Được tặng thưởng Huy hiệu\nlàm nhiệm vụ Quốc Tế, Bằng khen của Trung ương Đoàn Thanh niên Cộng sản\nHồ Chí Minh. Nghỉ hưu.\nBà chánh thất: Trần Thị Huần, sinh năm 1957. Người làng Thổ Cầu, Nghĩa\nDân. Làm việc ở Công ty Cầu III Thăng Long, nghỉ hưu.\nCác con: 01 con trai\nNgô Thế Tỉnh\n01 con gái, Ngô Thị Mỹ Hạnh, sinh năm 1985. Lấy chồng tên là Đỗ Biên\nThùy, sinh năm 1982. Sinh trai: Biên Cương, gái: Trà My, Thảo Quyên.",
    "photo_url": null,
    "parent_id_temp": "ngo-the-thap"
  },
  {
    "id_temp": "ngo-quoc-viet",
    "name": "Ngô Quốc Việt",
    "han_name": null,
    "generation": 12,
    "death_anniversary": "01-12-1968 (Dương lịch)",
    "grave": null,
    "details": "Là con trưởng cụ Ngô Thế Bạn. Sinh năm 1950. Năm 1968 đi bộ đội vào\nChiến trường Miền Nam. Hy sinh khi đánh Đồn Long Khốt, tỉnh Long An. Được\ntặng thưởng Huy chương Chiến sỹ Vẻ vang. Liệt sỹ chống Mỹ cứu nước.\nPhần mộ ở xứ Nghĩ trang Liệt sỹ xã Phạm Ngũ Lão.",
    "photo_url": null,
    "parent_id_temp": "ngo-the-ban"
